{
  "manifest_version": 3,
  "name": "Ayman Prolific Studies Notifier",
  "version": "2.0.4",
  "description": "Premium automated notifier and reservation system for Prolific studies.",

  "permissions": [
    "storage",
    "notifications",
    "offscreen",
    "tabs",
    "alarms",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://app.prolific.com/*",
    "https://internal-api.prolific.com/*",
    "https://web.whatsapp.com/*"
  ],

  "background": {
    "service_worker": "dist/background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://app.prolific.com/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["dist/whatsapp-monitor.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "title": "Ayman Prolific Notifier"
  },

  "icons": {
    "16": "imgs/icon16.png",
    "48": "imgs/icon48.png",
    "128": "imgs/icon128.png"
  }
}
