{
  "manifest_version": 3,
  "name": "Ayman Prolific Studies Notifier",
  "version": "2.2.0",
  "description": "Professional Prolific study notifier and auto-reserve assistant with AI solver and WhatsApp monitor.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://app.prolific.com/*",
    "https://*.prolific.com/*",
    "https://web.whatsapp.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "imgs/icon16.png",
      "48": "imgs/icon48.png",
      "128": "imgs/icon128.png"
    }
  },
  "icons": {
    "16": "imgs/icon16.png",
    "48": "imgs/icon48.png",
    "128": "imgs/icon128.png"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.prolific.com/*",
        "https://*.prolific.com/*"
      ],
      "js": [
        "dist/content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "dist/whatsapp-monitor.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "audio/audio.html",
        "imgs/*",
        "dist/study-scraper.js",
        "dist/study-solver.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
